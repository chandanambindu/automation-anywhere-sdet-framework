# Example env for running the local mock API server
# Do NOT store credentials or real API keys here.
API_BASE_URL=http://localhost:3001
# UI base URL can remain the real site for UI tests (not used by mock)
BASE_URL=https://www.automationanywhere.com/products/enterprise/community-edition
# Example placeholders - replace in your local `.env` (which is gitignored)
USERNAME=your@example.com
PASSWORD=yourpassword
